{
  "name": "void",
  "version": "1.2.0",
  "description": "VØID 1.2 — Offline Audio Slicer & Remixer",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Justin Ray",
  "license": "ISC",
  "build": {
    "appId": "com.jray.void",
    "productName": "VØID",
    "files": [
      "src/main.js",
      "src/index.html",
      "assets/void_icon.ico"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/void_icon.ico"
    },
    "portable": {
      "artifactName": "VOID_1.2_Portable.exe"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
